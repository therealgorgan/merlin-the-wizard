{
  "name": "merlin-the-wizard",
  "version": "0.6.2",
  "description": "Windows 11 desktop companion that recreates the Microsoft Agent Merlin sprite as a modern LLM-backed assistant. Multi-provider (Groq, OpenRouter, Ollama, MiniMax, Hermes Agent), voice in/out, screen capture, web search, custom characters.",
  "main": "out/main/index.js",
  "author": "therealgorgan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/therealgorgan/merlin-the-wizard.git"
  },
  "homepage": "https://github.com/therealgorgan/merlin-the-wizard#readme",
  "bugs": {
    "url": "https://github.com/therealgorgan/merlin-the-wizard/issues"
  },
  "keywords": [
    "electron",
    "desktop-assistant",
    "ai",
    "llm",
    "microsoft-agent",
    "clippy",
    "merlin",
    "anthropic",
    "openai",
    "groq",
    "ollama",
    "hermes-agent",
    "voice",
    "tts",
    "whisper"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "dist": "npm run assets && electron-vite build && electron-builder",
    "dist:portable": "npm run assets && electron-vite build && electron-builder --config.win.target=portable",
    "assets": "node scripts/prepare-merlin-assets.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ai-sdk/groq": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@anthropic-ai/sdk": "^0.32.1",
    "ai": "^4.0.0",
    "clippyjs": "^0.0.3",
    "electron-log": "^5.4.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "jquery": "3.5.1",
    "marked": "^14.1.3",
    "msedge-tts": "^2.0.5",
    "ollama-ai-provider": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jquery": "^3.5.30",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "jimp": "^0.22.12",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
