# Copy this file to `.env` and fill in any keys you want available at dev time.
# Everything here is OPTIONAL — you can also paste keys into Settings at
# runtime, where they're encrypted via Windows DPAPI. The .env path exists
# mainly for development convenience so you don't have to retype them on
# every fresh checkout.
#
# .env is gitignored. Never commit secrets.

# Groq — free tier with generous rate limits, used by default for chat.
# Get a key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter — gives you Claude, GPT-5, Gemini, etc. behind one key.
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax — the M2.7 family. Cheap and capable.
# Get a key at https://platform.minimax.io/user-center/basic-information/interface-key
# MINIMAX_API_KEY=eyJh...

# Tavily — for the web_search tool. Without this, web_search falls back to
# DuckDuckGo Instant Answers (free but very limited).
# Get a key at https://tavily.com
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hermes Agent (self-hosted) — if you run your own Hermes Agent gateway,
# set the bearer key here OR (better) paste it into Settings → AI Provider
# at runtime so it goes through DPAPI.
# Get this from your Hermes box: `grep ^API_SERVER_KEY= ~/.hermes/.env`
# HERMES_API_KEY=hermes-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
